{
  "name": "nostringer",
  "version": "0.4.0",
  "description": "Unlinkable ring signatures for Nostr-compatible secp256k1 keys",
  "main": "./dist/cjs/src/index.cjs",
  "module": "./dist/esm/src/index.js",
  "types": "./dist/esm/src/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/src/index.cjs",
      "import": "./dist/esm/src/index.js",
      "types": "./dist/esm/src/index.d.ts"
    }
  },
  "scripts": {
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run fix:build",
    "fix:build": "node ./scripts/fix-build.js",
    "prepublishOnly": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "lint": "eslint src test --ext .ts",
    "debug:flakiness": "node --experimental-vm-modules node_modules/jest/bin/jest.js test/e2e/flakiness.test.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "nostr",
    "cryptography",
    "ring-signature",
    "secp256k1",
    "privacy",
    "monero",
    "typescript"
  ],
  "author": "AbdelStark",
  "license": "MIT",
  "dependencies": {
    "@noble/hashes": "^1.3.0",
    "@noble/secp256k1": "^2.0.0",
    "@nostr-dev-kit/ndk": "^2.5.0",
    "fs": "^0.0.1-security",
    "nostr-tools": "^2.1.5"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}